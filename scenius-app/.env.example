# Supabase — fill in from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Full URL of the deployed app (no trailing slash). Used as the email confirmation redirect base.
# e.g. https://scenius.vercel.app  or  http://localhost:3000 for local dev
NEXT_PUBLIC_SITE_URL=

# Server-only. Never expose to the browser.
# Used by integration tests + admin paths.
SUPABASE_SECRET_KEY=

# Optional: separate Supabase project URL for integration tests.
# SUPABASE_TEST_URL=
